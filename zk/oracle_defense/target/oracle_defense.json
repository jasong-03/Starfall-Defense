{"noir_version":"1.0.0-beta.9+6abff2f16e1c1314ba30708d1cf032a536de3d19","hash":"16913864245398099792","abi":{"parameters":[{"name":"prices","type":{"kind":"array","length":20,"type":{"kind":"integer","sign":"unsigned","width":64}},"visibility":"private"},{"name":"token_types","type":{"kind":"array","length":20,"type":{"kind":"integer","sign":"unsigned","width":8}},"visibility":"private"},{"name":"player_shot","type":{"kind":"array","length":20,"type":{"kind":"boolean"}},"visibility":"private"},{"name":"num_active","type":{"kind":"integer","sign":"unsigned","width":8},"visibility":"private"},{"name":"real_trb","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"real_eth","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"real_btc","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"correct_shots","type":{"kind":"integer","sign":"unsigned","width":8},"visibility":"public"},{"name":"incorrect_shots","type":{"kind":"integer","sign":"unsigned","width":8},"visibility":"public"},{"name":"missed_bad","type":{"kind":"integer","sign":"unsigned","width":8},"visibility":"public"},{"name":"total_data_points","type":{"kind":"integer","sign":"unsigned","width":8},"visibility":"public"},{"name":"game_seed","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"}],"return_type":null,"error_types":{"4413905523624953343":{"error_kind":"string","string":"Correct shots mismatch"},"5019202896831570965":{"error_kind":"string","string":"attempt to add with overflow"},"7233212735005103307":{"error_kind":"string","string":"attempt to multiply with overflow"},"7566188003106073342":{"error_kind":"string","string":"Too many data points"},"8946123575773877116":{"error_kind":"string","string":"Active count mismatch"},"9757687818450881777":{"error_kind":"string","string":"Incorrect shots mismatch"},"15439095968366801535":{"error_kind":"string","string":"Missed bad data mismatch"}}},"bytecode":"","debug_symbols":"","file_map":{"50":{"source":"// Oracle Defense ZK Circuit\n// Proves: \"I correctly identified bad oracle price data\"\n//\n// The game shows falling crypto prices. Some are real (good data),\n// some are manipulated (bad data). The player must shoot bad data\n// and let good data through.\n//\n// This circuit proves the player's classification accuracy without\n// revealing their specific detection strategy.\n\nglobal MAX_DATA_POINTS: u32 = 20;\n\nfn is_price_bad(price_cents: u64, real_price_cents: u64) -> bool {\n    // Bad = deviates >40% from real price\n    // price < real*60/100 OR price > real*140/100\n    let lower_bound = real_price_cents * 60 / 100;\n    let upper_bound = real_price_cents * 140 / 100;\n    (price_cents < lower_bound) | (price_cents > upper_bound)\n}\n\nfn main(\n    // === Private inputs (witness) ===\n    prices: [u64; 20],\n    token_types: [u8; 20],\n    player_shot: [bool; 20],\n    num_active: u8,\n\n    // === Public inputs (on-chain) ===\n    real_trb: pub u64,\n    real_eth: pub u64,\n    real_btc: pub u64,\n    correct_shots: pub u8,\n    incorrect_shots: pub u8,\n    missed_bad: pub u8,\n    total_data_points: pub u8,\n    game_seed: pub u64,\n) {\n    assert(num_active == total_data_points, \"Active count mismatch\");\n    assert(num_active as u32 <= MAX_DATA_POINTS, \"Too many data points\");\n\n    let mut computed_correct: u8 = 0;\n    let mut computed_incorrect: u8 = 0;\n    let mut computed_missed: u8 = 0;\n\n    for i in 0..20 {\n        if (i as u8) < num_active {\n            let real_price = if token_types[i] == 0 {\n                real_trb\n            } else if token_types[i] == 1 {\n                real_eth\n            } else {\n                real_btc\n            };\n\n            let actually_bad = is_price_bad(prices[i], real_price);\n\n            if player_shot[i] {\n                if actually_bad {\n                    computed_correct += 1;\n                } else {\n                    computed_incorrect += 1;\n                }\n            } else if actually_bad {\n                computed_missed += 1;\n            }\n        }\n    }\n\n    assert(computed_correct == correct_shots, \"Correct shots mismatch\");\n    assert(computed_incorrect == incorrect_shots, \"Incorrect shots mismatch\");\n    assert(computed_missed == missed_bad, \"Missed bad data mismatch\");\n}\n\n#[test]\nfn test_perfect_game() {\n    let mut prices: [u64; 20] = [0; 20];\n    let mut token_types: [u8; 20] = [0; 20];\n    let mut player_shot: [bool; 20] = [false; 20];\n\n    prices[0] = 1558;       // TRB good\n    prices[1] = 231;        // TRB bad (way low)\n    prices[2] = 205400;     // ETH good\n    prices[3] = 20000000;   // BTC bad (3x real)\n    prices[4] = 50000;      // ETH bad (way low)\n\n    token_types[0] = 0;\n    token_types[1] = 0;\n    token_types[2] = 1;\n    token_types[3] = 2;\n    token_types[4] = 1;\n\n    player_shot[1] = true;  // shot bad TRB\n    player_shot[3] = true;  // shot bad BTC\n    player_shot[4] = true;  // shot bad ETH\n\n    main(prices, token_types, player_shot, 5, 1558, 205400, 6880300, 3, 0, 0, 5, 12345);\n}\n\n#[test]\nfn test_mixed_game() {\n    let mut prices: [u64; 20] = [0; 20];\n    let mut token_types: [u8; 20] = [0; 20];\n    let mut player_shot: [bool; 20] = [false; 20];\n\n    prices[0] = 1560;       // TRB good - accidentally shot\n    prices[1] = 231;        // TRB bad - correctly shot\n    prices[2] = 6880000;    // BTC good - ignored\n    prices[3] = 50000;      // ETH bad - missed\n\n    token_types[0] = 0;\n    token_types[1] = 0;\n    token_types[2] = 2;\n    token_types[3] = 1;\n\n    player_shot[0] = true;\n    player_shot[1] = true;\n\n    main(prices, token_types, player_shot, 4, 1558, 205400, 6880300, 1, 1, 1, 4, 99999);\n}\n","path":"/Users/vbi2/Documents/hackathon/sui/game/zk/oracle_defense/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient","directive_invert"]}